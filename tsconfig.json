{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["jest", "react", "react-native"]
  },
  "include": ["src", "__tests__", "jest.setup.ts", "App.tsx"]
}
